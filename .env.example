AWS_REGION=eu-central-1
STACK_NAME=chess-move-validator-frontend
GITHUB_CONNECTION_ARN=arn:aws:codeconnections:REGION:ACCOUNT_ID:connection/CONNECTION_ID
GITHUB_REPOSITORY=OWNER/REPOSITORY
GITHUB_BRANCH=main
CONFIRMATION_EMAIL_FROM=verified-sender@example.com
# Optional: S3 bucket for `aws cloudformation package` Lambda artifacts.
# Defaults to ${STACK_NAME}-art-<accountId>, created automatically if missing.
# PACKAGE_BUCKET=my-cfn-artifacts-bucket
